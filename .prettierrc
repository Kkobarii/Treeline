{
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "all",
	"printWidth": 140,
	"bracketSameLine": true,
	"arrowParens": "avoid",
	"endOfLine": "lf",
	"semi": true,
	"singleAttributePerLine": true,
	"tabWidth": 4,
	"plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss", "prettier-plugin-organize-imports"],
	"overrides": [{ "files": "*.svelte", "options": { "parser": "svelte" } }]
}
